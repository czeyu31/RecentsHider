<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- TopAppBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="back"
            android:padding="6dp"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="文件中转站"
            android:textSize="18sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <ImageView
            android:id="@+id/btnScan"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_wifi"
            android:padding="6dp"
            android:background="@drawable/bg_icon_button"
            app:tint="@color/primary"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:padding="6dp"
            android:background="@drawable/bg_icon_button"
            app:tint="@color/primary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 发送区 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="发送区"
                android:textSize="18sp"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- 上传区域 -->
            <FrameLayout
                android:id="@+id/uploadArea"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="@drawable/bg_upload_area"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_back"
                        android:rotation="90"
                        app:tint="@color/primary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvUploadText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击选择文件"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="支持所有文件类型"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- 6个功能按钮 -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/btnFile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_ft_file"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="文件"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMedia"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_ft_media"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="媒体"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnClipboard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_ft_clipboard"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剪贴板"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_ft_text"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="文本"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnFolder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_ft_folder"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="文件夹"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnApp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_rounded_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_ft_app"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="应用"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </GridLayout>

            <!-- 分享链接显示 -->
            <TextView
                android:id="@+id/tvUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:textIsSelectable="true"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                android:padding="14dp"
                android:background="@drawable/bg_rounded_input" />

            <!-- 已添加文件列表 -->
            <LinearLayout
                android:id="@+id/fileListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <!-- 附近设备 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_wifi"
                            android:padding="8dp"
                            android:background="@drawable/bg_tool_icon_primary"
                            app:tint="@color/primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvDeviceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="搜索附近设备"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/tvDeviceCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击扫描"
                            android:textSize="11sp"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnQuickConnect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="快速连接"
                        android:textSize="12sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_icon_button"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 发现的设备列表 -->
            <LinearLayout
                android:id="@+id/deviceListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <!-- 接收与进度 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="接收文件"
                android:textSize="18sp"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <!-- 接收链接输入框 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etReceiveUrl"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="粘贴接收链接"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_variant"
                    android:background="@drawable/bg_rounded_input"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:inputType="textUri"
                    android:imeOptions="actionDone"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/btnReceive"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="接收"
                    android:textSize="14sp"
                    android:textColor="@color/background"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_rounded_primary"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- 传输任务 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="传输任务"
                android:textSize="18sp"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- 传输任务列表 -->
            <LinearLayout
                android:id="@+id/taskListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- 统计卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="本次传输"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface_variant" />

                        <TextView
                            android:id="@+id/tvTodayTransfer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 MB"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="可用空间"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface_variant" />

                        <TextView
                            android:id="@+id/tvAvailableSpace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="计算中..."
                            android:textSize="18sp"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
